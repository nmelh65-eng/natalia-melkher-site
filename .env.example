# Публичный URL сайта (канонический, Open Graph, sitemap).
# На Vercel Preview можно не задавать: подставится https://${VERCEL_URL} (см. lib/site-url.ts).
NEXT_PUBLIC_SITE_URL=https://natalia-melkher.vercel.app

# Соцсети (опционально; иначе Instagram — ссылка по умолчанию, остальные — mailto на почту)
# NEXT_PUBLIC_INSTAGRAM_URL=
# NEXT_PUBLIC_FACEBOOK_URL=
# NEXT_PUBLIC_YOUTUBE_URL=
# NEXT_PUBLIC_TIKTOK_URL=

# Аналитика (публичные ID; при отсутствии подставляются значения по умолчанию из кода)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-8V03G4N6D4
NEXT_PUBLIC_YANDEX_METRIKA_ID=108502761

# Хранилище произведений (Upstash / Vercel Redis — rediss://...)
REDIS_URL=

# Админ-панель: в production на Vercel задайте обязательно (без дефолтов в коде)
ADMIN_SECRET=
ADMIN_PASSWORD=

# AI «Муза» (OpenRouter). Без ключа чат работает в офлайн-режиме.
OPENROUTER_API_KEY=

# Только production: включить GET /api/debug для диагностики Redis (после входа админа)
# ENABLE_ADMIN_DEBUG=true
